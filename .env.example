# ============================================================
#  SAHIL 804 BOT v4.2.0 — Environment Variables
#  ─────────────────────────────────────────────────────────
#  SETUP:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in values below (every section marked REQUIRED)
#   3. NEVER commit .env to GitHub — it's in .gitignore
#
#  ON RAILWAY:
#   Go to Project → Variables tab and add each key manually.
#   Do NOT upload a .env file to Railway — use Variables UI.
# ============================================================


# ─── SERVER ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production


# ─── SESSION SECRET [REQUIRED] ───────────────────────────
# Must be a long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars


# ─── ADMIN PANEL [REQUIRED] ──────────────────────────────
# These credentials are for the /admin.html panel
ADMIN_EMAIL=sahilhackerx110@gmail.com
ADMIN_PASSWORD=ChangeThisToAStrongPassword123!


# ─── BOT SETTINGS ────────────────────────────────────────
BOT_NAME=SAHIL 804 BOT
BOT_PREFIX=.
OWNER_NUMBER=923496049312
OWNER_BACKUP=923711158307
OWNER_NAME=Legend Sahil Hacker 804


# ═══════════════════════════════════════════════════════
#  FIREBASE SETUP [ALL REQUIRED]
#  ─────────────────────────────────────────────────────
#  WHERE TO GET THESE VALUES:
#   1. Go to Firebase Console → https://console.firebase.google.com
#   2. Select your project (or create one)
#   3. Project Settings → Service Accounts tab
#   4. Click "Generate new private key" → downloads a JSON file
#   5. Open the JSON file and copy values below
#
#  JSON Field → Environment Variable mapping:
#   "project_id"      → FIREBASE_PROJECT_ID
#   "client_email"    → FIREBASE_CLIENT_EMAIL
#   "private_key_id"  → FIREBASE_PRIVATE_KEY_ID
#   "client_id"       → FIREBASE_CLIENT_ID
#   "private_key"     → FIREBASE_PRIVATE_KEY (see note below)
# ═══════════════════════════════════════════════════════

FIREBASE_PROJECT_ID=sahilhaccker-bot

# From the JSON file — looks like: firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sahilhaccker-bot.iam.gserviceaccount.com

# 40-character hex string from the JSON file
FIREBASE_PRIVATE_KEY_ID=abcdef1234567890abcdef1234567890abcdef12

# Numeric client ID from the JSON file
FIREBASE_CLIENT_ID=123456789012345678901

# ─── PRIVATE KEY — VERY IMPORTANT FORMAT ─────────────────
# Copy the ENTIRE private_key value from the JSON file.
# It starts with -----BEGIN PRIVATE KEY----- and ends with -----END PRIVATE KEY-----
#
# In .env file, it MUST be wrapped in double quotes AND use \n for line breaks:
#
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0...(rest of key)...\n-----END PRIVATE KEY-----\n"
#
# COMMON MISTAKES:
#  ✗ Forgetting the surrounding double quotes
#  ✗ Using actual line breaks instead of \n
#  ✗ Copying only part of the key
#  ✗ Extra spaces around the \n
#
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_YOUR_ENTIRE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Realtime Database URL (find in Firebase Console → Realtime Database)
# Format: https://YOUR-PROJECT-default-rtdb.REGION.firebasedatabase.app
FIREBASE_DATABASE_URL=https://sahilhaccker-bot-default-rtdb.asia-southeast1.firebasedatabase.app

# Optional — from Firebase Console → Project Settings → General → Your apps → Web app
FIREBASE_API_KEY=
FIREBASE_MESSAGING_SENDER_ID=847927392090
FIREBASE_APP_ID=1:847927392090:web:d8ea7143f75731872fe563


# ─── OPTIONAL API KEYS ────────────────────────────────────
# These are for specific bot commands. Bot works without them
# but those commands will return errors.

# RapidAPI — for YouTube/TikTok download commands
# Get from: https://rapidapi.com
RAPIDAPI_KEY=

# Hadith API — for Islamic hadith command
# Get from: https://hadithapi.com
HADITH_API_KEY=

# OMDB — for movie/series info command
# Get from: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=


# ─── BOT FEATURES ─────────────────────────────────────────
# true = feature ON | false = feature OFF
AUTO_REACT=true
AUTO_REPLY=true
AUTO_READ=true
ANTI_DELETE=true
WELCOME_MSG=true
GOODBYE_MSG=true
ANTI_SPAM=true
ANTI_LINK=false
ANTI_BOT=true
ANTI_BAD_WORD=false
CHATBOT=false
TTS=true
VIEW_ONCE=true
ANTI_DELETE2=true
